# SGS Field Tracker — Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Connection (option 1: individual params)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=field_tracker

# PostgreSQL Connection (option 2: full DSN - overrides individual params above)
# DATABASE_URL=postgres://postgres:your_password@localhost:5432/field_tracker?sslmode=disable

# Server port (default: 8080)
PORT=8080
