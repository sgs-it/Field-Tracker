+          child: TextField(
+            controller: _searchCtrl,
+            style: const TextStyle(color: Colors.white, fontSize: 13),
+            decoration: InputDecoration(
+              hintText: 'Search site, worker, or location...',
+              hintStyle: const TextStyle(color: Colors.grey, fontSize: 12),
