+          const SizedBox(height: 4),
+          Container(
+            width: 340,
+            constraints: const BoxConstraints(maxHeight: 250),
+            decoration: BoxDecoration(
+              color: const Color(0xFF1E1E26).withOpacity(0.95),
+              borderRadius: BorderRadius.circular(8),
